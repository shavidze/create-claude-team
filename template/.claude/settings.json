{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git mv *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push origin*)",
      "Bash(git push -u origin*)",
      "Bash(git pull)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git remote *)",
      "Bash(git rm *)",
      "Bash(git merge-base*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(node --version)",
      "Bash(node *)",
      "Bash(npm --version)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git config --global *)",
      "Bash(git commit --amend*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push *--no-verify*)",
      "Bash(git rebase*)",
      "Bash(git filter-branch*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/pre-push-verify.mjs" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/check-uncommitted.mjs" }
        ]
      }
    ]
  }
}
